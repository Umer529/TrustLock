<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ─── Standard permissions ─────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- API 34+: required when foregroundServiceType="specialUse" -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- API 33+: runtime permission for posting notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- Protected permission: user must grant this manually via
         Settings → Apps → Special app access → Usage access -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- NOTE: BIND_ACCESSIBILITY_SERVICE and BIND_DEVICE_ADMIN are system-level
         permissions that protect our service/receiver from non-system binding.
         They are declared on the component, not here in uses-permission. -->

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:name=".ScreenPactApp"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TrustLock">

        <!-- ─── Activities ──────────────────────────────────────────────── -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.welcome.WelcomeActivity"
            android:exported="false" />

        <activity
            android:name=".ui.registration.RegistrationActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.permissions.PermissionsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.apps.AddAppLimitActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Full-screen lock screen shown when a tracked app exceeds its time limit -->
        <activity
            android:name=".ui.blocked.BlockedAppActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.TrustLock.Fullscreen" />

        <!-- ─── Receivers ───────────────────────────────────────────────── -->

        <!-- Restarts ScreenTimeMonitorService after device reboot -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Device Admin: prevents uninstall and can force-lock the device.
             User must activate this in Settings → Security → Device admin apps. -->
        <receiver
            android:name=".receiver.ScreenPactDeviceAdminReceiver"
            android:description="@string/device_admin_description"
            android:label="@string/device_admin_label"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_policies" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!-- ─── Services ────────────────────────────────────────────────── -->

        <!-- Accessibility service: detects foreground app changes and launches
             the lock screen when a tracked app exceeds its time limit.
             User must enable this in Settings → Accessibility. -->
        <service
            android:name=".service.AppBlockingAccessibilityService"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Foreground service: polls UsageStatsManager on a timer to accumulate
             per-app screen time and notify when a limit is reached.
             foregroundServiceType="specialUse" required on API 34+. -->
        <service
            android:name=".service.ScreenTimeMonitorService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <!-- Required by Google Play for specialUse foreground services (API 34+) -->
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Monitors per-app foreground usage time and enforces guardian-approved screen time limits" />
        </service>

    </application>

</manifest>
