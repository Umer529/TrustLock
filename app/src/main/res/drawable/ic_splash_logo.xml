<?xml version="1.0" encoding="utf-8"?>
<!-- Stacked logo: dark-purple shield with white lock.
     200x200 viewport. Shield geometrically centered at (100, 100):
     x extent 38-162 (mid 100), y extent 15-185 (mid 100). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="160dp"
    android:height="160dp"
    android:viewportWidth="200"
    android:viewportHeight="200">

    <!-- Shield outer (darker purple) -->
    <path
        android:pathData="M100,15 L162,40 L162,113 Q162,160 100,185 Q38,160 38,113 L38,40 Z"
        android:fillColor="#5A4FD8" />

    <!-- Shield inner depth layer (even darker for shadow) -->
    <path
        android:pathData="M100,28 L152,49 L152,111 Q152,150 100,173 Q48,150 48,111 L48,49 Z"
        android:fillColor="#3F36B5" />

    <!-- Lock body (white) -->
    <path
        android:pathData="M86,110 L114,110 Q118,110 118,114 L118,128 Q118,132 114,132 L86,132 Q82,132 82,128 L82,114 Q82,110 86,110 Z"
        android:fillColor="#FFFFFF" />

    <!-- Lock shackle (white) -->
    <path
        android:pathData="M91,110 L91,102 Q91,92 100,92 Q109,92 109,102 L109,110"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent" />

    <!-- Keyhole circle (purple) -->
    <path
        android:pathData="M100,119 m-3,0 a3,3 0,1,0 6,0 a3,3 0,1,0 -6,0"
        android:fillColor="#5A4FD8" />

    <!-- Keyhole stem (purple) -->
    <path
        android:pathData="M98.5,119 L101.5,119 L101.5,125 L98.5,125 Z"
        android:fillColor="#5A4FD8" />
</vector>
