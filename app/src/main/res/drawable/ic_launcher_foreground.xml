<?xml version="1.0" encoding="utf-8"?>
<!-- ScreenPact adaptive icon foreground. 108x108 viewport; adaptive safe zone is the
     centered 72x72 region (18-90 on each axis). Shield is geometrically centered at
     (54, 54): x extent 31-77 (mid 54), y extent 22-88 (mid 55, very close to viewport
     center; the rounded bottom shifts visual mass slightly above geometric center). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Translucent shield highlight (depth) -->
    <path
        android:pathData="M54,22 L77,33 L77,60 Q77,77 54,88 Q31,77 31,60 L31,33 Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.18" />

    <!-- Shield outline (white stroke) -->
    <path
        android:pathData="M54,22 L77,33 L77,60 Q77,77 54,88 Q31,77 31,60 L31,33 Z"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:fillColor="@android:color/transparent" />

    <!-- Lock body (white) -->
    <path
        android:pathData="M48,62 L60,62 Q62,62 62,64 L62,70 Q62,72 60,72 L48,72 Q46,72 46,70 L46,64 Q46,62 48,62 Z"
        android:fillColor="#FFFFFF" />

    <!-- Lock shackle (white) -->
    <path
        android:pathData="M50,62 L50,58 Q50,54 54,54 Q58,54 58,58 L58,62"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2.2"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent" />

    <!-- Keyhole circle (dark purple, matches background) -->
    <path
        android:pathData="M54,67 m-1.5,0 a1.5,1.5 0,1,0 3,0 a1.5,1.5 0,1,0 -3,0"
        android:fillColor="#5A4FD8" />

    <!-- Keyhole stem -->
    <path
        android:pathData="M53.2,67 L54.8,67 L54.8,70 L53.2,70 Z"
        android:fillColor="#5A4FD8" />
</vector>
