<?xml version="1.0" encoding="utf-8"?>
<!-- ScreenPact icon-only logo. Single-color shield with a lock cutout — Android
     tints notification icons to one color, so multi-fill isn't supported.
     24x24 viewport. Geometrically centered: x extent 5.5-18.5 (mid 12),
     y extent 3-21 (mid 12). Uses evenOdd fill so the lock body subtracts. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="96dp"
    android:height="96dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="
            M12,3 L18.5,5.5 L18.5,13.5 Q18.5,18 12,21 Q5.5,18 5.5,13.5 L5.5,5.5 Z
            M10.4,12.5 L13.6,12.5 Q14,12.5 14,12.9 L14,15.1 Q14,15.5 13.6,15.5 L10.4,15.5 Q10,15.5 10,15.1 L10,12.9 Q10,12.5 10.4,12.5 Z" />

    <!-- Lock shackle (drawn on top as a thin stroke; tinted same as shield) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="0.8"
        android:strokeLineCap="round"
        android:fillColor="@android:color/transparent"
        android:pathData="M10.8,12.5 L10.8,11 Q10.8,9.5 12,9.5 Q13.2,9.5 13.2,11 L13.2,12.5" />
</vector>
