<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.TrustLock" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryVariant">@color/purple_variant</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/purple_light</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowAnimationStyle">@style/WindowAnimation</item>
    </style>

    <style name="Theme.TrustLock" parent="Base.Theme.TrustLock" />

    <style name="Theme.TrustLock.Fullscreen" parent="Base.Theme.TrustLock">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>

    <!-- Splash theme: solid dark background and no animation in/out so the launcher → splash
         handoff is seamless. The reveal animation is driven entirely in code. -->
    <style name="Theme.TrustLock.Splash" parent="Base.Theme.TrustLock">
        <item name="android:windowBackground">@color/splash_background</item>
        <item name="android:statusBarColor">@color/splash_background</item>
        <item name="android:navigationBarColor">@color/splash_background</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!-- Smooth activity transitions -->
    <style name="WindowAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/fade_in</item>
        <item name="android:activityOpenExitAnimation">@anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/fade_out</item>
    </style>

    <!-- ── Input fields ──────────────────────────────────────────────────── -->

    <style name="ScreenPact.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/outline</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxBackgroundColor">@color/surface_variant</item>
        <item name="hintTextColor">@color/purple_light</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- ── Buttons ───────────────────────────────────────────────────────── -->

    <style name="ScreenPact.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/purple_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="ScreenPact.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="ScreenPact.Button.Danger" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/error</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/error</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <!-- ── Cards ─────────────────────────────────────────────────────────── -->

    <style name="ScreenPact.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface_variant</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="ScreenPact.Card.Purple" parent="ScreenPact.Card">
        <item name="cardBackgroundColor">@color/purple_surface</item>
        <item name="strokeColor">@color/purple_dim</item>
    </style>

</resources>
