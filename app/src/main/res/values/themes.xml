<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.TrustLock" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryVariant">@color/purple_variant</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/purple_light</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
    </style>

    <style name="Theme.TrustLock" parent="Base.Theme.TrustLock" />

    <!-- Full-screen overlay for blocked app screen -->
    <style name="Theme.TrustLock.Fullscreen" parent="Base.Theme.TrustLock">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>

    <!-- TextInputLayout outlined style with purple accent -->
    <style name="ScreenPact.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/purple_primary</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- Primary filled button -->
    <style name="ScreenPact.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/purple_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Outline secondary button -->
    <style name="ScreenPact.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/purple_primary</item>
        <item name="android:textColor">@color/purple_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>
</resources>
