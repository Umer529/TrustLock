<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:background="@drawable/bg_purple_chip"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_shield"
                android:tint="@color/purple_light"
                android:contentDescription="ScreenPact" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="PAIRING"
                android:textColor="@color/purple_light"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your pairing code"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Share this code with your guardian. They'll enter it on their phone to connect to you. Keep this screen open until they're done."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp" />

        <!-- Code pill -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp">

            <TextView
                android:id="@+id/tvCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_code_pill"
                android:paddingVertical="28dp"
                android:gravity="center"
                android:text="——————"
                android:textColor="@color/text_primary"
                android:textSize="48sp"
                android:letterSpacing="0.30"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progressGenerating"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/purple_primary" />
        </FrameLayout>

        <!-- Share button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShareCode"
            style="@style/ScreenPact.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:enabled="false"
            android:text="Share code"
            android:textSize="15sp" />

        <!-- Status block -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="32dp"
            android:padding="16dp"
            android:background="@drawable/bg_perm_card_granted"
            android:visibility="gone"
            android:id="@+id/connectedBlock">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_check_circle"
                android:contentDescription="Connected" />

            <TextView
                android:id="@+id/tvConnectedText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Connected"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvWaitingStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="Waiting for guardian to connect…"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <!-- Continue (only after pairing) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            style="@style/ScreenPact.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:text="Continue"
            android:textSize="15sp"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
