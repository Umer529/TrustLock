<?xml version="1.0" encoding="utf-8"?>
<!-- Tappable card. The entire row is the action — no anonymous checkbox.
     Right side shows either a status pill ("Required" / "Optional") +
     chevron when ungranted, or a green check + "Granted" pill when granted. -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:foreground="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/surface_variant"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top row: icon · title+desc · status/check -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="14dp">

                <View
                    android:id="@+id/iconBackdrop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_purple_circle" />

                <ImageView
                    android:id="@+id/ivPermIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:tint="@color/purple_light"
                    android:contentDescription="permission" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Small category tag so the user understands what this permission is FOR -->
                <TextView
                    android:id="@+id/tvPermCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/purple_light"
                    android:textSize="9sp"
                    android:letterSpacing="0.18"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvPermName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvPermDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:lineSpacingExtra="2dp" />
            </LinearLayout>

            <!-- Granted check (visible when granted) -->
            <ImageView
                android:id="@+id/ivGrantedCheck"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_check_circle"
                android:visibility="gone"
                android:contentDescription="Granted" />

            <!-- Chevron (visible when ungranted) -->
            <ImageView
                android:id="@+id/ivChevron"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_chevron_right"
                android:contentDescription="Open settings" />
        </LinearLayout>

        <!-- Bottom row: status pill (right-aligned) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/tvStatusPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
